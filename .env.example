# Configurar en Vercel: Project → Settings → Environment Variables

# OpenAI: usado para Whisper (transcripción) y gpt-4o-mini (extracción)
OPENAI_API_KEY=sk-...

# Resend: para enviar el email de la nota
RESEND_API_KEY=re_...

# Opcional. Si no configuras un dominio en Resend, deja el default 'Consulta <onboarding@resend.dev>'.
# Con dominio verificado: 'Consulta <consulta@tudominio.com>'
RESEND_FROM=Consulta <onboarding@resend.dev>
